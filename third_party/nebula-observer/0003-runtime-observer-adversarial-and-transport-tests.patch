+func TestRuntimeObserverSharedProtocolFixtures(t *testing.T) {
+	directory := os.Getenv("MESH_NEBULA_OBSERVER_FIXTURES")
+	if directory == "" {
+		t.Skip("shared fixture directory is supplied by the Mesh smoke")
+	}
+	validRequest, err := os.ReadFile(filepath.Join(directory, "request-valid.jsonl"))
+	if err != nil {
+		t.Fatal(err)
+	}
+	if nonce, err := decodeRuntimeObserverRequest(validRequest); err != nil || nonce != runtimeObserverTestNonce {
+		t.Fatalf("valid request = %q, %v", nonce, err)
+	}
+	invalidRequests, err := filepath.Glob(filepath.Join(directory, "request-invalid-*.jsonl"))
+	if err != nil || len(invalidRequests) == 0 {
+		t.Fatalf("invalid fixture glob = %v, %v", invalidRequests, err)
+	}
+	for _, path := range invalidRequests {
+		message, err := os.ReadFile(path)
+		if err != nil {
+			t.Fatal(err)
+		}
+		if _, err := decodeRuntimeObserverRequest(message); err == nil {
+			t.Errorf("accepted invalid fixture %s", filepath.Base(path))
+		}
+	}
+
+	validSnapshot, err := os.ReadFile(filepath.Join(directory, "snapshot-empty-valid.jsonl"))
+	if err != nil {
+		t.Fatal(err)
+	}
+	var snapshot runtimeObserverSnapshot
+	if err := json.Unmarshal(bytes.TrimSuffix(validSnapshot, []byte{'\n'}), &snapshot); err != nil {
+		t.Fatal(err)
+	}
+	reencoded, err := json.Marshal(snapshot)
+	if err != nil {
+		t.Fatal(err)
+	}
+	reencoded = append(reencoded, '\n')
+	if !bytes.Equal(reencoded, validSnapshot) || snapshot.Schema != runtimeObserverSnapshotSchema || snapshot.Nonce != runtimeObserverTestNonce {
+		t.Fatalf("snapshot fixture is not the canonical v2 allowlist")
+	}
+}
