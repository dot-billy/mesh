+func TestRuntimeObserverServerRoundTripAndCleanShutdown(t *testing.T) {
+	server, options := newRuntimeObserverTestServer(t)
+	socketInfo, err := os.Lstat(options.socketPath)
+	if err != nil {
+		t.Fatal(err)
+	}
+	stat := socketInfo.Sys().(*syscall.Stat_t)
+	if socketInfo.Mode()&os.ModeSocket == 0 || socketInfo.Mode().Perm() != 0o600 || stat.Uid != uint32(os.Getuid()) || stat.Nlink != 1 {
+		t.Fatalf("unsafe socket metadata: mode=%v uid=%d nlink=%d", socketInfo.Mode(), stat.Uid, stat.Nlink)
+	}
+
+	connection, err := net.DialUnix("unix", nil, &net.UnixAddr{Name: options.socketPath, Net: "unix"})
+	if err != nil {
+		t.Fatal(err)
+	}
+	request := []byte(`{"schema":"nebula.runtime-observer.request.v1","operation":"snapshot","nonce":"` + runtimeObserverTestNonce + `"}` + "\n")
+	if _, err := connection.Write(request); err != nil {
+		t.Fatal(err)
+	}
+	response, err := io.ReadAll(connection)
+	if err != nil {
+		t.Fatal(err)
+	}
+	_ = connection.Close()
+	var snapshot runtimeObserverSnapshot
+	if err := json.Unmarshal(response, &snapshot); err != nil {
+		t.Fatalf("response %q: %v", response, err)
+	}
+	if snapshot.Schema != runtimeObserverSnapshotSchema || snapshot.Nonce != runtimeObserverTestNonce || snapshot.SampleSequence != 1 {
+		t.Fatalf("unexpected response %q: %#v", response, snapshot)
+	}
+
+	if err := server.Close(); err != nil {
+		t.Fatal(err)
+	}
+	if _, err := os.Lstat(options.socketPath); !errors.Is(err, os.ErrNotExist) {
+		t.Fatalf("socket remains after shutdown: %v", err)
+	}
+	if err := server.Close(); err != nil {
+		t.Fatal(err)
+	}
+}
+
+func TestRuntimeObserverServerRejectsWrongPeerAndMalformedInput(t *testing.T) {
+	t.Run("peer credential", func(t *testing.T) {
+		observer, options := newRuntimeObserverTestState(t)
+		options.expectedPeer = uint32(os.Getuid()) + 1
+		server, err := startRuntimeObserverServer(observer, options)
+		if err != nil {
+			t.Fatal(err)
+		}
+		defer server.Close()
+		connection, err := net.Dial("unix", options.socketPath)
+		if err != nil {
+			t.Fatal(err)
+		}
+		_ = connection.SetDeadline(time.Now().Add(time.Second))
+		_, _ = connection.Write([]byte("x\n"))
+		response, _ := io.ReadAll(connection)
+		_ = connection.Close()
+		if len(response) != 0 {
+			t.Fatalf("credential rejection leaked response %q", response)
+		}
+	})
+
+	t.Run("malformed and trailing", func(t *testing.T) {
+		server, options := newRuntimeObserverTestServer(t)
+		defer server.Close()
+		for _, request := range [][]byte{[]byte("x\n"), append([]byte(`{"schema":"nebula.runtime-observer.request.v1","operation":"snapshot","nonce":"`+runtimeObserverTestNonce+`"}`+"\n"), 'x')} {
+			connection, err := net.Dial("unix", options.socketPath)
+			if err != nil {
+				t.Fatal(err)
+			}
+			_ = connection.SetDeadline(time.Now().Add(time.Second))
+			_, _ = connection.Write(request)
+			response, _ := io.ReadAll(connection)
+			_ = connection.Close()
+			if string(response) != "{\"error\":\"invalid request\"}\n" {
+				t.Fatalf("request %q response %q", request, response)
+			}
+		}
+	})
+}
+
+func TestRuntimeObserverServerRefusesExistingPathAndWrongParentMode(t *testing.T) {
+	observer, options := newRuntimeObserverTestState(t)
+	if err := os.WriteFile(options.socketPath, []byte("do not replace"), 0o600); err != nil {
+		t.Fatal(err)
+	}
+	if server, err := startRuntimeObserverServer(observer, options); err == nil {
+		server.Close()
+		t.Fatal("accepted pre-existing path")
+	}
+	contents, err := os.ReadFile(options.socketPath)
+	if err != nil || string(contents) != "do not replace" {
+		t.Fatalf("pre-existing path changed: %q, %v", contents, err)
+	}
+	if err := os.Remove(options.socketPath); err != nil {
+		t.Fatal(err)
+	}
+	if err := os.Chmod(filepath.Dir(options.socketPath), 0o755); err != nil {
+		t.Fatal(err)
+	}
+	if server, err := startRuntimeObserverServer(observer, options); err == nil {
+		server.Close()
+		t.Fatal("accepted wrong parent mode")
+	}
+}
+
+func TestRuntimeObserverServerDoesNotUnlinkReplacement(t *testing.T) {
+	server, options := newRuntimeObserverTestServer(t)
+	moved := options.socketPath + ".moved"
+	if err := os.Rename(options.socketPath, moved); err != nil {
+		t.Fatal(err)
+	}
+	if err := os.WriteFile(options.socketPath, []byte("replacement"), 0o600); err != nil {
+		t.Fatal(err)
+	}
+	if err := server.Close(); err != nil {
+		t.Fatal(err)
+	}
+	contents, err := os.ReadFile(options.socketPath)
+	if err != nil || string(contents) != "replacement" {
+		t.Fatalf("replacement was removed: %q, %v", contents, err)
+	}
+}
+
+func TestRuntimeObserverServerDoesNotAdoptChmodWindowReplacement(t *testing.T) {
+	observer, options := newRuntimeObserverTestState(t)
+	moved := options.socketPath + ".created"
+	var replacement *net.UnixListener
+	var hookErr error
+	options.afterSocketChmod = func() {
+		if hookErr = os.Rename(options.socketPath, moved); hookErr != nil {
+			return
+		}
+		replacement, hookErr = net.ListenUnix("unix", &net.UnixAddr{Name: options.socketPath, Net: "unix"})
+		if hookErr != nil {
+			return
+		}
+		replacement.SetUnlinkOnClose(false)
+		hookErr = os.Chmod(options.socketPath, options.socketMode)
+	}
+
+	server, startErr := startRuntimeObserverServer(observer, options)
+	if replacement != nil {
+		defer replacement.Close()
+		defer os.Remove(options.socketPath)
+	}
+	if hookErr != nil {
+		if server != nil {
+			_ = server.Close()
+		}
+		t.Fatal(hookErr)
+	}
+	if server != nil {
+		_ = server.Close()
+	}
+	if startErr == nil {
+		t.Error("accepted replacement exchanged after socket chmod")
+	}
+	info, err := os.Lstat(options.socketPath)
+	if err != nil {
+		t.Fatalf("chmod-window replacement did not survive cleanup: %v", err)
+	}
+	stat := info.Sys().(*syscall.Stat_t)
+	if info.Mode()&os.ModeSocket == 0 || info.Mode().Perm() != options.socketMode || stat.Uid != options.expectedOwner || stat.Nlink != 1 {
+		t.Fatalf("unexpected replacement metadata: mode=%v uid=%d nlink=%d", info.Mode(), stat.Uid, stat.Nlink)
+	}
+	connection, err := net.DialTimeout("unix", options.socketPath, time.Second)
+	if err != nil {
+		t.Fatalf("replacement socket is not live: %v", err)
+	}
+	_ = connection.Close()
+}
+
+func TestRuntimeObserverServerShutdownClosesSlowClients(t *testing.T) {
+	server, options := newRuntimeObserverTestServer(t)
+	first, err := net.Dial("unix", options.socketPath)
+	if err != nil {
+		t.Fatal(err)
+	}
+	second, err := net.Dial("unix", options.socketPath)
+	if err != nil {
+		t.Fatal(err)
+	}
+	finished := make(chan struct{})
+	go func() {
+		_ = server.Close()
+		close(finished)
+	}()
+	select {
+	case <-finished:
+	case <-time.After(time.Second):
+		t.Fatal("shutdown exceeded bound")
+	}
+	_ = first.Close()
+	_ = second.Close()
+}
+
+func TestRuntimeObserverServerTotalDeadlineCapsReadPhase(t *testing.T) {
+	observer, options := newRuntimeObserverTestState(t)
+	options.readTimeout = 2 * time.Second
+	options.writeTimeout = 2 * time.Second
+	options.totalTimeout = 75 * time.Millisecond
+	server, err := startRuntimeObserverServer(observer, options)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer server.Close()
+	connection, err := net.Dial("unix", options.socketPath)
+	if err != nil {
+		t.Fatal(err)
+	}
+	defer connection.Close()
+	_ = connection.SetReadDeadline(time.Now().Add(time.Second))
+	started := time.Now()
+	var response [1]byte
+	_, _ = connection.Read(response[:])
+	if elapsed := time.Since(started); elapsed > 300*time.Millisecond {
+		t.Fatalf("read phase exceeded total deadline: %s", elapsed)
+	}
+}
+
+func newRuntimeObserverTestServer(t *testing.T) (*runtimeObserverServer, runtimeObserverServerOptions) {
+	t.Helper()
+	observer, options := newRuntimeObserverTestState(t)
+	server, err := startRuntimeObserverServer(observer, options)
+	if err != nil {
+		t.Fatal(err)
+	}
+	return server, options
+}
+
+func newRuntimeObserverTestState(t *testing.T) (*RuntimeObserver, runtimeObserverServerOptions) {
+	t.Helper()
+	directory, err := os.MkdirTemp("/tmp", "nebula-observer-test-")
+	if err != nil {
+		t.Fatal(err)
+	}
+	t.Cleanup(func() { _ = os.RemoveAll(directory) })
+	if err := os.Chmod(directory, 0o700); err != nil {
+		t.Fatal(err)
+	}
+	hostMap := &HostMap{Indexes: map[uint32]*HostInfo{}, Hosts: map[netip.Addr]*HostInfo{}}
+	handshakes := &HandshakeManager{indexes: map[uint32]*HandshakeHostInfo{}}
+	lightHouse := &LightHouse{}
+	configured := []netip.Addr{}
+	lightHouse.lighthouses.Store(&configured)
+	observer := newRuntimeObserverWithInstance(hostMap, handshakes, lightHouse, time.Now(), runtimeObserverTestNonce)
+	options := productionRuntimeObserverServerOptions()
+	options.socketPath = filepath.Join(directory, "observer.sock")
+	options.expectedOwner = uint32(os.Getuid())
+	options.expectedPeer = uint32(os.Getuid())
+	options.readTimeout = 250 * time.Millisecond
+	options.writeTimeout = 250 * time.Millisecond
+	options.totalTimeout = 500 * time.Millisecond
+	return observer, options
+}
