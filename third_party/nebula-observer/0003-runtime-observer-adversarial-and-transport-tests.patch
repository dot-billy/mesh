+// This regression test audits the production control-flow boundary itself.
+// DecryptDanger failures and replay-window Update failures return before the
+// hook. CloseTunnel and the relay wrapper live in readOutsidePackets, which is
+// forbidden from calling the hook; a terminal relay's recursively processed
+// inner packet reaches decrypt/decryptToTun and is counted there exactly once.
+func TestRuntimeObserverRejectsBadAEADReplayCloseAndRelayAccounting(t *testing.T) {
+	fileSet := token.NewFileSet()
+	parsed, err := parser.ParseFile(fileSet, "outside.go", nil, 0)
+	if err != nil {
+		t.Fatal(err)
+	}
+	functions := map[string]*ast.FuncDecl{}
+	for _, declaration := range parsed.Decls {
+		if function, ok := declaration.(*ast.FuncDecl); ok {
+			functions[function.Name.Name] = function
+		}
+	}
+	for _, name := range []string{"decrypt", "decryptToTun"} {
+		function := functions[name]
+		if function == nil {
+			t.Fatalf("missing %s", name)
+		}
+		decryptIndex := statementIndexWithSelector(function.Body.List, "DecryptDanger")
+		updateIndex := statementIndexWithSelector(function.Body.List, "Update")
+		hookIndex := statementIndexWithSelector(function.Body.List, "recordAuthenticatedRX")
+		if decryptIndex < 0 || updateIndex <= decryptIndex || hookIndex <= updateIndex {
+			t.Fatalf("%s hook order decrypt=%d update=%d hook=%d", name, decryptIndex, updateIndex, hookIndex)
+		}
+		if !statementsContainRejectingIf(function.Body.List[decryptIndex+1 : updateIndex]) {
+			t.Fatalf("%s AEAD failure no longer returns before accounting", name)
+		}
+		updateStatement, ok := function.Body.List[updateIndex].(*ast.IfStmt)
+		if !ok || !statementsContainReturn(updateStatement.Body.List) {
+			t.Fatalf("%s replay commit is no longer a rejecting if statement", name)
+		}
+		if _, ok := function.Body.List[hookIndex].(*ast.ExprStmt); !ok {
+			t.Fatalf("%s hook is no longer an unconditional post-check statement", name)
+		}
+	}
+	readOutside := functions["readOutsidePackets"]
+	if readOutside == nil || !functionContainsSelector(readOutside, "CloseTunnel") || !functionContainsSelector(readOutside, "MessageRelay") {
+		t.Fatal("close/relay receive branches are missing")
+	}
+	if functionContainsSelector(readOutside, "recordAuthenticatedRX") {
+		t.Fatal("close or relay wrapper can advance authenticated RX")
+	}
+
+	totalHooks := 0
+	for _, function := range functions {
+		ast.Inspect(function, func(node ast.Node) bool {
+			if selector, ok := node.(*ast.SelectorExpr); ok && selector.Sel.Name == "recordAuthenticatedRX" {
+				totalHooks++
+			}
+			return true
+		})
+	}
+	if totalHooks != 2 {
+		t.Fatalf("outside.go hook count = %d, want 2", totalHooks)
+	}
+}
+
+func statementIndexWithSelector(statements []ast.Stmt, name string) int {
+	for index, statement := range statements {
+		found := false
+		ast.Inspect(statement, func(node ast.Node) bool {
+			if selector, ok := node.(*ast.SelectorExpr); ok && selector.Sel.Name == name {
+				found = true
+			}
+			return true
+		})
+		if found {
+			return index
+		}
+	}
+	return -1
+}
+
+func functionContainsSelector(function *ast.FuncDecl, name string) bool {
+	found := false
+	ast.Inspect(function, func(node ast.Node) bool {
+		if selector, ok := node.(*ast.SelectorExpr); ok && selector.Sel.Name == name {
+			found = true
+		}
+		return true
+	})
+	return found
+}
+
+func statementsContainRejectingIf(statements []ast.Stmt) bool {
+	for _, statement := range statements {
+		if condition, ok := statement.(*ast.IfStmt); ok && statementsContainReturn(condition.Body.List) {
+			return true
+		}
+	}
+	return false
+}
+
+func statementsContainReturn(statements []ast.Stmt) bool {
+	for _, statement := range statements {
+		found := false
+		ast.Inspect(statement, func(node ast.Node) bool {
+			if _, ok := node.(*ast.ReturnStmt); ok {
+				found = true
+			}
+			return true
+		})
+		if found {
+			return true
+		}
+	}
+	return false
+}
+
+func TestDecodeRuntimeObserverRequestRejectsAdversarialForms(t *testing.T) {
+	canonical := `{"schema":"nebula.runtime-observer.request.v1","operation":"snapshot","nonce":"` + runtimeObserverTestNonce + `"}` + "\n"
+	if nonce, err := decodeRuntimeObserverRequest([]byte(canonical)); err != nil || nonce != runtimeObserverTestNonce {
+		t.Fatalf("canonical request = %q, %v", nonce, err)
+	}
+	tests := map[string]string{
+		"missing newline": strings.TrimSuffix(canonical, "\n"),
+		"uppercase nonce": strings.Replace(canonical, runtimeObserverTestNonce, strings.ToUpper(runtimeObserverTestNonce), 1),
+		"duplicate":       strings.Replace(canonical, `}`, `,"nonce":"`+runtimeObserverTestNonce+`"}`, 1),
+		"reordered":       `{"operation":"snapshot","schema":"nebula.runtime-observer.request.v1","nonce":"` + runtimeObserverTestNonce + `"}` + "\n",
+		"unknown":         strings.Replace(canonical, `}`, `,"path":"/tmp/x"}`, 1),
+		"trailing":        canonical + "x",
+	}
+	for name, message := range tests {
+		t.Run(name, func(t *testing.T) {
+			if _, err := decodeRuntimeObserverRequest([]byte(message)); err == nil {
+				t.Fatalf("accepted %q", message)
+			}
+		})
+	}
+}
