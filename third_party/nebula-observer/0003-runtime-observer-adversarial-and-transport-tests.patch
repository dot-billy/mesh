+func TestRuntimeObserverSnapshotAccountingAndBounds(t *testing.T) {
+	startedAt := time.Now().Add(-10 * time.Minute)
+	firstAddress := netip.MustParseAddr("10.42.0.1")
+	secondAddress := netip.MustParseAddr("10.42.0.9")
+	first := &HostInfo{vpnAddrs: []netip.Addr{firstAddress}}
+	second := &HostInfo{vpnAddrs: []netip.Addr{secondAddress}}
+	hostMap := &HostMap{
+		Indexes: map[uint32]*HostInfo{1: first, 2: second},
+		Hosts:   map[netip.Addr]*HostInfo{firstAddress: first, secondAddress: second},
+	}
+	handshakes := &HandshakeManager{indexes: map[uint32]*HandshakeHostInfo{3: {}}}
+	lightHouse := &LightHouse{}
+	configured := []netip.Addr{firstAddress}
+	lightHouse.lighthouses.Store(&configured)
+	observer := newRuntimeObserverWithInstance(hostMap, handshakes, lightHouse, startedAt, runtimeObserverTestNonce)
+
+	observer.recordHandshakeCompleted(first)
+	observer.recordHandshakeCompleted(second)
+	observer.recordHandshakeTimedOut()
+	nowElapsed := time.Since(startedAt)
+	first.runtimeObserverLastAuthenticatedRX.Store(uint64(nowElapsed-90*time.Second) + 1)
+	observer.recordLighthouseAuthenticatedRX(first, uint64(nowElapsed-90*time.Second)+1)
+	second.runtimeObserverLastAuthenticatedRX.Store(uint64(nowElapsed-4*time.Minute) + 1)
+
+	snapshot, err := observer.snapshot(runtimeObserverTestNonce)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if snapshot.Schema != runtimeObserverSnapshotSchema || snapshot.Nonce != runtimeObserverTestNonce || snapshot.ProcessInstanceID != runtimeObserverTestNonce {
+		t.Fatalf("unexpected identity fields: %#v", snapshot)
+	}
+	if snapshot.SampleSequence != 1 || snapshot.ProcessUptimeMS < uint64((9*time.Minute)/time.Millisecond) {
+		t.Fatalf("unexpected sequence or uptime: %#v", snapshot)
+	}
+	if snapshot.Handshakes.CompletedTotal != 2 || snapshot.Handshakes.TimedOutTotal != 1 || snapshot.Handshakes.Pending != 1 || snapshot.Handshakes.MostRecentCompletionAgeMS == nil {
+		t.Fatalf("unexpected handshake snapshot: %#v", snapshot.Handshakes)
+	}
+	if snapshot.Peers.Established != 2 || snapshot.Peers.AuthenticatedRXWithin2m != 1 || snapshot.Peers.AuthenticatedRXWithin5m != 2 ||
+		snapshot.Peers.OldestAuthenticatedRXAgeMS == nil || *snapshot.Peers.OldestAuthenticatedRXAgeMS < uint64((3*time.Minute)/time.Millisecond) {
+		t.Fatalf("unexpected peer snapshot: %#v", snapshot.Peers)
+	}
+	if snapshot.Lighthouses.Configured != 1 || snapshot.Lighthouses.Established != 1 || snapshot.Lighthouses.AuthenticatedRXWithin2m != 1 ||
+		snapshot.Lighthouses.MostRecentAuthenticatedRXAgeMS == nil || len(snapshot.Lighthouses.Entries) != 1 ||
+		snapshot.Lighthouses.Entries[0].VPNIP != firstAddress.String() {
+		t.Fatalf("unexpected lighthouse snapshot: %#v", snapshot.Lighthouses)
+	}
+	delete(hostMap.Indexes, 1)
+	delete(hostMap.Hosts, firstAddress)
+	evicted, err := observer.snapshot(runtimeObserverTestNonce)
+	if err != nil {
+		t.Fatal(err)
+	}
+	if evicted.Lighthouses.Established != 0 || evicted.Lighthouses.AuthenticatedRXWithin2m != 0 ||
+		evicted.Lighthouses.MostRecentAuthenticatedRXAgeMS == nil || len(evicted.Lighthouses.Entries) != 0 ||
+		*evicted.Lighthouses.MostRecentAuthenticatedRXAgeMS < uint64((89*time.Second)/time.Millisecond) {
+		t.Fatalf("lighthouse receive history was lost with its host-map entry: %#v", evicted.Lighthouses)
+	}
+	if next, err := observer.snapshot(runtimeObserverTestNonce); err != nil || next.SampleSequence != 3 {
+		t.Fatalf("third snapshot = %#v, %v", next, err)
+	}
+}
