+func TestRuntimeObserverSaturatesCounters(t *testing.T) {
+	var value atomic.Uint64
+	value.Store(runtimeObserverMaxJSONInteger - 1)
+	if got := saturatingIncrement(&value, runtimeObserverMaxJSONInteger); got != runtimeObserverMaxJSONInteger {
+		t.Fatalf("first increment = %d", got)
+	}
+	if got := saturatingIncrement(&value, runtimeObserverMaxJSONInteger); got != runtimeObserverMaxJSONInteger || value.Load() != runtimeObserverMaxJSONInteger {
+		t.Fatalf("saturated increment = %d, stored = %d", got, value.Load())
+	}
+	if got := addSaturated(runtimeObserverMaxAggregate-1, 2, runtimeObserverMaxAggregate); got != runtimeObserverMaxAggregate {
+		t.Fatalf("aggregate = %d", got)
+	}
+}
