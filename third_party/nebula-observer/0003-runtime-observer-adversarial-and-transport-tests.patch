+func TestRuntimeObserverLighthouseAggregateIsCoherentDuringRXUpdate(t *testing.T) {
+	startedAt := time.Now().Add(-2 * time.Minute)
+	address := netip.MustParseAddr("10.42.0.1")
+	host := &HostInfo{vpnAddrs: []netip.Addr{address}}
+	hostMap := &HostMap{
+		Indexes: map[uint32]*HostInfo{1: host},
+		Hosts:   map[netip.Addr]*HostInfo{address: host},
+	}
+	handshakes := &HandshakeManager{indexes: map[uint32]*HandshakeHostInfo{}}
+	lightHouse := &LightHouse{}
+	configured := []netip.Addr{address}
+	lightHouse.lighthouses.Store(&configured)
+	observer := newRuntimeObserverWithInstance(hostMap, handshakes, lightHouse, startedAt, runtimeObserverTestNonce)
+
+	nowElapsed := time.Since(startedAt)
+	observer.recordLighthouseAuthenticatedRX(host, uint64(nowElapsed-90*time.Second)+1)
+	host.runtimeObserverLastAuthenticatedRX.Store(uint64(nowElapsed-time.Second) + 1)
