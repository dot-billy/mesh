+func TestRuntimeObserverSnapshotIsRaceSafe(t *testing.T) {
+	address := netip.MustParseAddr("10.42.0.1")
+	host := &HostInfo{vpnAddrs: []netip.Addr{address}}
+	hostMap := &HostMap{Indexes: map[uint32]*HostInfo{1: host}, Hosts: map[netip.Addr]*HostInfo{address: host}}
+	handshakes := &HandshakeManager{indexes: map[uint32]*HandshakeHostInfo{}}
+	lightHouse := &LightHouse{}
+	configured := []netip.Addr{address}
+	lightHouse.lighthouses.Store(&configured)
+	observer := newRuntimeObserverWithInstance(hostMap, handshakes, lightHouse, time.Now(), runtimeObserverTestNonce)
+
+	var workers sync.WaitGroup
+	for index := 0; index < 4; index++ {
+		workers.Add(1)
+		go func() {
+			defer workers.Done()
+			for count := 0; count < 100; count++ {
+				observer.recordHandshakeCompleted(host)
+				observer.recordAuthenticatedRX(host)
+				observer.recordHandshakeTimedOut()
+				if _, err := observer.snapshot(runtimeObserverTestNonce); err != nil {
+					t.Errorf("snapshot: %v", err)
+					return
+				}
+			}
+		}()
+	}
+	workers.Wait()
+}
