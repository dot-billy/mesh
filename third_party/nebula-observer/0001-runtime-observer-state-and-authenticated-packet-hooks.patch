diff --git a/runtime_observer.go b/runtime_observer.go
new file mode 100644
index 0000000000000000000000000000000000000000..0040272a290c40a114d4d27750c0846355068b21
--- /dev/null
+++ b/runtime_observer.go
@@ -0,0 +1,403 @@
+package nebula
+
+import (
+	"crypto/rand"
+	"encoding/hex"
+	"encoding/json"
+	"errors"
+	"net/netip"
+	"sort"
+	"sync"
+	"sync/atomic"
+	"time"
+)
+
+const (
+	runtimeObserverRequestSchema  = "nebula.runtime-observer.request.v1"
+	runtimeObserverSnapshotSchema = "nebula.runtime-observer.snapshot.v2"
+	runtimeObserverOperation      = "snapshot"
+	runtimeObserverNonceBytes     = 16
+	runtimeObserverNonceHexLength = runtimeObserverNonceBytes * 2
+	runtimeObserverMaxRequest     = 256
+	runtimeObserverMaxResponse    = 16 << 10
+	runtimeObserverMaxEntries     = 8
+	runtimeObserverMaxLighthouses = 64
+	runtimeObserverMaxJSONInteger = uint64(1<<53 - 1)
+	runtimeObserverMaxAggregate   = uint64(1<<32 - 1)
+	runtimeObserverRX2m           = 2 * time.Minute
+	runtimeObserverRX5m           = 5 * time.Minute
+)
+
+var errRuntimeObserverProtocol = errors.New("runtime observer protocol violation")
+
+// RuntimeObserver owns only bounded, process-local observation state. It has
+// no configuration, command, key, certificate, underlay-address, or packet
+// fields and is intentionally not exported through any general metrics API.
+type RuntimeObserver struct {
+	startedAt         time.Time
+	processInstanceID string
+	hostMap           *HostMap
+	handshakeManager  *HandshakeManager
+	lightHouse        *LightHouse
+	sampleSequence    atomic.Uint64
+	completedTotal    atomic.Uint64
+	timedOutTotal     atomic.Uint64
+	lastCompletion    atomic.Uint64
+	lighthouseMu      sync.Mutex
+	lighthouseRX      map[netip.Addr]uint64
+}
+
+type runtimeObserverSnapshot struct {
+	Schema            string                            `json:"schema"`
+	Nonce             string                            `json:"nonce"`
+	ProcessInstanceID string                            `json:"process_instance_id"`
+	SampleSequence    uint64                            `json:"sample_sequence"`
+	ProcessUptimeMS   uint64                            `json:"process_uptime_ms"`
+	Handshakes        runtimeObserverHandshakeSnapshot  `json:"handshakes"`
+	Peers             runtimeObserverPeerSnapshot       `json:"peers"`
+	Lighthouses       runtimeObserverLighthouseSnapshot `json:"lighthouses"`
+}
+
+type runtimeObserverHandshakeSnapshot struct {
+	CompletedTotal            uint64  `json:"completed_total"`
+	TimedOutTotal             uint64  `json:"timed_out_total"`
+	Pending                   uint64  `json:"pending"`
+	MostRecentCompletionAgeMS *uint64 `json:"most_recent_completion_age_ms"`
+}
+
+type runtimeObserverPeerSnapshot struct {
+	Established                uint64  `json:"established"`
+	AuthenticatedRXWithin2m    uint64  `json:"authenticated_rx_within_2m"`
+	AuthenticatedRXWithin5m    uint64  `json:"authenticated_rx_within_5m"`
+	OldestAuthenticatedRXAgeMS *uint64 `json:"oldest_authenticated_rx_age_ms"`
+}
+
+type runtimeObserverLighthouseSnapshot struct {
+	Configured              uint64                           `json:"configured"`
+	Established             uint64                           `json:"established"`
+	AuthenticatedRXWithin2m uint64                           `json:"authenticated_rx_within_2m"`
+	AuthenticatedRXWithin5m uint64                           `json:"authenticated_rx_within_5m"`
+	MostRecentAuthenticatedRXAgeMS *uint64                   `json:"most_recent_authenticated_rx_age_ms"`
+	Overflow                bool                             `json:"overflow"`
+	Entries                 []runtimeObserverLighthouseEntry `json:"entries"`
+}
+
+type runtimeObserverLighthouseEntry struct {
+	VPNIP                    string  `json:"vpn_ip"`
+	Established              bool    `json:"established"`
+	LastHandshakeAgeMS       *uint64 `json:"last_handshake_age_ms"`
+	LastAuthenticatedRXAgeMS *uint64 `json:"last_authenticated_rx_age_ms"`
+}
+
+func newRuntimeObserver(hostMap *HostMap, handshakeManager *HandshakeManager, lightHouse *LightHouse) (*RuntimeObserver, error) {
+	var instance [runtimeObserverNonceBytes]byte
+	if _, err := rand.Read(instance[:]); err != nil {
+		return nil, errors.New("could not initialize runtime observer")
+	}
+	return newRuntimeObserverWithInstance(hostMap, handshakeManager, lightHouse, time.Now(), hex.EncodeToString(instance[:])), nil
+}
+
+func newRuntimeObserverWithInstance(hostMap *HostMap, handshakeManager *HandshakeManager, lightHouse *LightHouse, startedAt time.Time, instanceID string) *RuntimeObserver {
+	return &RuntimeObserver{
+		startedAt:         startedAt,
+		processInstanceID: instanceID,
+		hostMap:           hostMap,
+		handshakeManager:  handshakeManager,
+		lightHouse:        lightHouse,
+		lighthouseRX:      make(map[netip.Addr]uint64),
+	}
+}
+
+// elapsedMark stores process-relative monotonic nanoseconds plus one, leaving
+// zero as the unambiguous "not observed in this process" value.
+func (o *RuntimeObserver) elapsedMark() uint64 {
+	elapsed := time.Since(o.startedAt)
+	if elapsed < 0 {
+		elapsed = 0
+	}
+	ns := uint64(elapsed)
+	if ns == ^uint64(0) {
+		return ns
+	}
+	return ns + 1
+}
+
+func (o *RuntimeObserver) recordHandshakeCompleted(hostInfo *HostInfo) {
+	if o == nil || hostInfo == nil {
+		return
+	}
+	mark := o.elapsedMark()
+	hostInfo.runtimeObserverLastHandshake.Store(mark)
+	o.lastCompletion.Store(mark)
+	saturatingIncrement(&o.completedTotal, runtimeObserverMaxJSONInteger)
+}
+
+func (o *RuntimeObserver) recordHandshakeTimedOut() {
+	if o != nil {
+		saturatingIncrement(&o.timedOutTotal, runtimeObserverMaxJSONInteger)
+	}
+}
+
+func (o *RuntimeObserver) recordAuthenticatedRX(hostInfo *HostInfo) {
+	if o != nil && hostInfo != nil {
+		mark := o.elapsedMark()
+		hostInfo.runtimeObserverLastAuthenticatedRX.Store(mark)
+		o.recordLighthouseAuthenticatedRX(hostInfo, mark)
+	}
+}
+
+func (o *RuntimeObserver) recordLighthouseAuthenticatedRX(hostInfo *HostInfo, mark uint64) {
+	configured := o.lightHouse.GetLighthouses()
+	o.lighthouseMu.Lock()
+	defer o.lighthouseMu.Unlock()
+	if len(configured) > runtimeObserverMaxLighthouses {
+		clear(o.lighthouseRX)
+		return
+	}
+	o.pruneLighthouseRXLocked(configured)
+	for _, configuredAddress := range configured {
+		for _, hostAddress := range hostInfo.vpnAddrs {
+			if configuredAddress == hostAddress && mark > o.lighthouseRX[configuredAddress] {
+				o.lighthouseRX[configuredAddress] = mark
+				break
+			}
+		}
+	}
+}
+
+func (o *RuntimeObserver) mostRecentLighthouseAuthenticatedRX(configured []netip.Addr) uint64 {
+	o.lighthouseMu.Lock()
+	defer o.lighthouseMu.Unlock()
+	if len(configured) > runtimeObserverMaxLighthouses {
+		clear(o.lighthouseRX)
+		return 0
+	}
+	o.pruneLighthouseRXLocked(configured)
+	var latest uint64
+	for _, address := range configured {
+		if mark := o.lighthouseRX[address]; mark > latest {
+			latest = mark
+		}
+	}
+	return latest
+}
+
+func (o *RuntimeObserver) pruneLighthouseRXLocked(configured []netip.Addr) {
+	for observed := range o.lighthouseRX {
+		keep := false
+		for _, address := range configured {
+			if observed == address {
+				keep = true
+				break
+			}
+		}
+		if !keep {
+			delete(o.lighthouseRX, observed)
+		}
+	}
+}
+
+func saturatingIncrement(value *atomic.Uint64, maximum uint64) uint64 {
+	for {
+		current := value.Load()
+		if current >= maximum {
+			return maximum
+		}
+		if value.CompareAndSwap(current, current+1) {
+			return current + 1
+		}
+	}
+}
+
+func runtimeObserverAge(nowElapsed time.Duration, mark uint64) *uint64 {
+	if mark == 0 {
+		return nil
+	}
+	eventNS := mark - 1
+	nowNS := uint64(nowElapsed)
+	if eventNS > nowNS {
+		eventNS = nowNS
+	}
+	age := (nowNS - eventNS) / uint64(time.Millisecond)
+	if age > runtimeObserverMaxJSONInteger {
+		age = runtimeObserverMaxJSONInteger
+	}
+	return &age
+}
+
+func runtimeObserverSaturatedDurationMS(duration time.Duration) uint64 {
+	if duration <= 0 {
+		return 0
+	}
+	value := uint64(duration / time.Millisecond)
+	if value > runtimeObserverMaxJSONInteger {
+		return runtimeObserverMaxJSONInteger
+	}
+	return value
+}
+
+func runtimeObserverSaturatedLength(length int) uint64 {
+	if length <= 0 {
+		return 0
+	}
+	if uint64(length) > runtimeObserverMaxAggregate {
+		return runtimeObserverMaxAggregate
+	}
+	return uint64(length)
+}
+
+func (o *RuntimeObserver) snapshot(nonce string) (runtimeObserverSnapshot, error) {
+	if o == nil || !runtimeObserverValidNonce(nonce) || o.hostMap == nil || o.handshakeManager == nil || o.lightHouse == nil {
+		return runtimeObserverSnapshot{}, errRuntimeObserverProtocol
+	}
+	nowElapsed := time.Since(o.startedAt)
+	if nowElapsed < 0 {
+		nowElapsed = 0
+	}
+
+	o.handshakeManager.RLock()
+	pending := runtimeObserverSaturatedLength(len(o.handshakeManager.indexes))
+	o.handshakeManager.RUnlock()
+
+	configured := append([]netip.Addr(nil), o.lightHouse.GetLighthouses()...)
+	sort.Slice(configured, func(i, j int) bool { return configured[i].Compare(configured[j]) < 0 })
+
+	snapshot := runtimeObserverSnapshot{
+		Schema:            runtimeObserverSnapshotSchema,
+		Nonce:             nonce,
+		ProcessInstanceID: o.processInstanceID,
+		SampleSequence:    saturatingIncrement(&o.sampleSequence, runtimeObserverMaxJSONInteger),
+		ProcessUptimeMS:   runtimeObserverSaturatedDurationMS(nowElapsed),
+		Handshakes: runtimeObserverHandshakeSnapshot{
+			CompletedTotal:            o.completedTotal.Load(),
+			TimedOutTotal:             o.timedOutTotal.Load(),
+			Pending:                   pending,
+			MostRecentCompletionAgeMS: runtimeObserverAge(nowElapsed, o.lastCompletion.Load()),
+		},
+		Lighthouses: runtimeObserverLighthouseSnapshot{
+			Configured:                     runtimeObserverSaturatedLength(len(configured)),
+			MostRecentAuthenticatedRXAgeMS: runtimeObserverAge(nowElapsed, o.mostRecentLighthouseAuthenticatedRX(configured)),
+			Overflow:                       len(configured) > runtimeObserverMaxEntries,
+			Entries:                        make([]runtimeObserverLighthouseEntry, 0, runtimeObserverMaxEntries),
+		},
+	}
+
+	o.hostMap.RLock()
+	for _, hostInfo := range o.hostMap.Indexes {
+		snapshot.Peers.Established = addSaturated(snapshot.Peers.Established, 1, runtimeObserverMaxAggregate)
+		rxAge := runtimeObserverAge(nowElapsed, hostInfo.runtimeObserverLastAuthenticatedRX.Load())
+		if rxAge != nil {
+			snapshot.Peers.OldestAuthenticatedRXAgeMS = maxAge(snapshot.Peers.OldestAuthenticatedRXAgeMS, rxAge)
+			if *rxAge <= uint64(runtimeObserverRX5m/time.Millisecond) {
+				snapshot.Peers.AuthenticatedRXWithin5m = addSaturated(snapshot.Peers.AuthenticatedRXWithin5m, 1, runtimeObserverMaxAggregate)
+			}
+			if *rxAge <= uint64(runtimeObserverRX2m/time.Millisecond) {
+				snapshot.Peers.AuthenticatedRXWithin2m = addSaturated(snapshot.Peers.AuthenticatedRXWithin2m, 1, runtimeObserverMaxAggregate)
+			}
+		}
+	}
+
+	observedLighthouses := make(map[*HostInfo]struct{}, len(configured))
+	for _, address := range configured {
+		hostInfo := o.hostMap.Hosts[address]
+		if hostInfo == nil {
+			continue
+		}
+		if _, alreadyObserved := observedLighthouses[hostInfo]; alreadyObserved {
+			continue
+		}
+		observedLighthouses[hostInfo] = struct{}{}
+		snapshot.Lighthouses.Established = addSaturated(snapshot.Lighthouses.Established, 1, runtimeObserverMaxAggregate)
+		handshakeAge := runtimeObserverAge(nowElapsed, hostInfo.runtimeObserverLastHandshake.Load())
+		rxAge := runtimeObserverAge(nowElapsed, hostInfo.runtimeObserverLastAuthenticatedRX.Load())
+		snapshot.Lighthouses.MostRecentAuthenticatedRXAgeMS = minAge(snapshot.Lighthouses.MostRecentAuthenticatedRXAgeMS, rxAge)
+		if rxAge != nil && *rxAge <= uint64(runtimeObserverRX5m/time.Millisecond) {
+			snapshot.Lighthouses.AuthenticatedRXWithin5m = addSaturated(snapshot.Lighthouses.AuthenticatedRXWithin5m, 1, runtimeObserverMaxAggregate)
+		}
+		if rxAge != nil && *rxAge <= uint64(runtimeObserverRX2m/time.Millisecond) {
+			snapshot.Lighthouses.AuthenticatedRXWithin2m = addSaturated(snapshot.Lighthouses.AuthenticatedRXWithin2m, 1, runtimeObserverMaxAggregate)
+		}
+		if len(snapshot.Lighthouses.Entries) < runtimeObserverMaxEntries {
+			snapshot.Lighthouses.Entries = append(snapshot.Lighthouses.Entries, runtimeObserverLighthouseEntry{
+				VPNIP:                    address.String(),
+				Established:              true,
+				LastHandshakeAgeMS:       handshakeAge,
+				LastAuthenticatedRXAgeMS: rxAge,
+			})
+		}
+	}
+	o.hostMap.RUnlock()
+
+	return snapshot, nil
+}
+
+func addSaturated(left, right, maximum uint64) uint64 {
+	if left >= maximum || right >= maximum-left {
+		return maximum
+	}
+	return left + right
+}
+
+func maxAge(current, candidate *uint64) *uint64 {
+	if candidate == nil {
+		return current
+	}
+	if current == nil || *candidate > *current {
+		value := *candidate
+		return &value
+	}
+	return current
+}
+
+func minAge(current, candidate *uint64) *uint64 {
+	if candidate == nil {
+		return current
+	}
+	if current == nil || *candidate < *current {
+		value := *candidate
+		return &value
+	}
+	return current
+}
+
+func runtimeObserverValidNonce(nonce string) bool {
+	if len(nonce) != runtimeObserverNonceHexLength {
+		return false
+	}
+	for _, character := range nonce {
+		if !((character >= '0' && character <= '9') || (character >= 'a' && character <= 'f')) {
+			return false
+		}
+	}
+	return true
+}
+
+func decodeRuntimeObserverRequest(line []byte) (string, error) {
+	const prefix = `{"schema":"nebula.runtime-observer.request.v1","operation":"snapshot","nonce":"`
+	const suffix = "\"}\n"
+	if len(line) > runtimeObserverMaxRequest || len(line) != len(prefix)+runtimeObserverNonceHexLength+len(suffix) ||
+		string(line[:len(prefix)]) != prefix || string(line[len(line)-len(suffix):]) != suffix {
+		return "", errRuntimeObserverProtocol
+	}
+	nonce := string(line[len(prefix) : len(prefix)+runtimeObserverNonceHexLength])
+	if !runtimeObserverValidNonce(nonce) {
+		return "", errRuntimeObserverProtocol
+	}
+	return nonce, nil
+}
+
+func (o *RuntimeObserver) encodeSnapshot(nonce string) ([]byte, error) {
+	snapshot, err := o.snapshot(nonce)
+	if err != nil {
+		return nil, errRuntimeObserverProtocol
+	}
+	encoded, err := json.Marshal(snapshot)
+	if err != nil {
+		return nil, errRuntimeObserverProtocol
+	}
+	encoded = append(encoded, '\n')
+	if len(encoded) > runtimeObserverMaxResponse {
+		return nil, errRuntimeObserverProtocol
+	}
+	return encoded, nil
+}
